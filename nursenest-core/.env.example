# Copy to .env (do not commit .env). DigitalOcean: set these in App Platform → Settings → Environment.

# PostgreSQL (required)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
#
# Production-only: if set, runtime copies this into DATABASE_URL before Prisma connects (`src/lib/db/env-bootstrap.ts`).
# Use when App Platform stores the prod DSN under a separate secret name. CLI scripts still need DATABASE_URL or set this in the shell.
# PROD_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
#
# Prisma reads DATABASE_URL only (see prisma/schema.prisma). App runtime, `prisma migrate deploy`, and `npm run db:ensure-admin` must use the SAME DATABASE_URL (set in shell or .env for CLI).
#   cd nursenest-core && npm run db:validate && npm run db:deploy
# Empty database with no migration history: `npm run db:push` (syncs schema; dev/staging only unless you accept drift risk).
# Admin user (after schema exists): BOOTSTRAP_ADMIN_EMAIL=... BOOTSTRAP_ADMIN_PASSWORD=... npm run db:ensure-admin
# Optional login handle: BOOTSTRAP_ADMIN_USERNAME=handle (lowercase; unique)
# (Build does not run migrations automatically.)

# Monolith Postgres (optional). Used only by `npm run export:blog-json` to build `content/blog-legacy-export.json`.
# LEGACY_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/MONOLITH_DB?sslmode=require

# Auth.js / NextAuth — required in production for login and JWT sessions
AUTH_SECRET=generate_a_long_random_string
# Public origin users hit in the browser (no trailing path). Use your custom domain or *.ondigitalocean.app URL.
AUTH_URL=https://your-app.ondigitalocean.app

# Optional legacy names (Auth.js reads these too)
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=

# Trust reverse proxies (DigitalOcean). Usually leave default; next.config also sets a fallback.
# AUTH_TRUST_HOST=true

# Marketing / SEO canonical URL (optional; defaults in code)
# NEXT_PUBLIC_APP_URL=https://www.nursenest.ca

# Public marketing CDN (homepage screenshots, blog URL rewrites). Default matches marketing-cdn.catalog.json (CDN hostname).
# NEXT_PUBLIC_MARKETING_CDN_BASE=https://nursenest-images.tor1.cdn.digitaloceanspaces.com

# Marketing images: default is direct public HTTPS (NEXT_PUBLIC_MARKETING_CDN_BASE / catalog). No SPACES_* required.
# Private bucket — rewrite URLs to same-origin /api/marketing-assets/... (needs SPACES_KEY, SPACES_SECRET on server):
# NEXT_PUBLIC_MARKETING_USE_SPACES_PROXY=true
# Optional: after a direct public URL fails in the browser, retry via the proxy (also needs SPACES_*):
# NEXT_PUBLIC_MARKETING_USE_SPACES_PROXY_FALLBACK=true

# DigitalOcean Spaces — marketing images (logo, homepage screenshots). Canonical base URL and path stems live in:
#   src/config/marketing-cdn.catalog.json
# Regenerate committed URLs with: npm run generate:marketing-assets
# Server-side proxy (only when using /api/marketing-assets): SPACES_KEY, SPACES_SECRET, SPACES_REGION (e.g. tor1), SPACES_BUCKET (e.g. nursenest-images)
# Optional: SPACES_PREFIX, SPACES_ENDPOINT, MARKETING_CDN_BASE (override public URL written to marketing-assets.generated.ts)

# Optional: host merged marketing locale JSON on Spaces/CDN to avoid shipping ~9MB under public/i18n in the deploy artifact.
# Upload nursenest-core/public/i18n/*.json to the bucket (same filenames). Example:
#   aws s3 sync public/i18n s3://nursenest-images/i18n --endpoint-url …
# Then set (HTTPS base, no trailing slash):
# MARKETING_I18N_CDN_BASE=https://nursenest-images.tor1.cdn.digitaloceanspaces.com/i18n
# Server-side SSR and /api/assets/i18n/* will use CDN when set (API route redirects; async loader fetches).

# Admin i18n diagnostics: allow writing reports/i18n-status.json to disk (default off in production).
# ALLOW_DIAGNOSTICS_DISK_WRITE=true
