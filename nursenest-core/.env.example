# Required at runtime in production. Must be a PostgreSQL URL (postgresql:// or postgres://). No quotes in the value.
# Prisma reads only DATABASE_URL (no DIRECT_URL / SHADOW_DATABASE_URL in schema.prisma).
DATABASE_URL="postgresql://user:password@localhost:5432/nursenest_core"
NEXTAUTH_SECRET="replace-with-secure-random-string"
# Auth.js v5: set to the canonical public origin in production (e.g. https://www.nursenest.ca). Leave unset or omit empty — empty string breaks trustHost (see src/lib/auth-trust-env.ts).
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Legacy public site base (programmatic links)
NEXT_PUBLIC_NURSENEST_ASSETS_BASE="https://www.nursenest.ca"
# Public origin for Space-hosted images (CDN or Spaces URL with public read). Rewrites marketing + lesson thumbnails.
NEXT_PUBLIC_MARKETING_CDN_BASE="https://nursenest-images.tor1.digitaloceanspaces.com"
# When `1` (default), `/screenshots/*` marketing URLs use GET /api/marketing-screenshot/screenshots/* (needs SPACES_* at runtime).
# Set to `0` only if the bucket/CDN allows anonymous GET and you want the browser to load Spaces/CDN URLs directly.
NEXT_PUBLIC_MARKETING_SCREENSHOT_PROXY="1"
# Optional: full URL to logo on the Space when `generate:marketing-assets` did not discover one
# NEXT_PUBLIC_MARKETING_LOGO_URL=""
# DigitalOcean Spaces (S3 API) — `npm run generate:marketing-assets` + runtime hero/lesson screenshot proxy when NEXT_PUBLIC_MARKETING_SCREENSHOT_PROXY=1
SPACES_KEY=""
SPACES_SECRET=""
SPACES_REGION="tor1"
SPACES_BUCKET="nursenest-images"
# Optional overrides for the generator:
# SPACES_ENDPOINT="https://tor1.digitaloceanspaces.com"
# SPACES_PREFIX=""
# MARKETING_CDN_BASE="https://nursenest-images.tor1.digitaloceanspaces.com"
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Transactional email (Resend) — required in production for password reset (see src/lib/env/validate-email-env.ts)
RESEND_API_KEY=""
EMAIL_FROM="NurseNest <onboarding@resend.dev>"
# Inbox for support-assisted “forgot email” requests (falls back to SUPPORT_EMAIL)
ACCOUNT_RECOVERY_INBOX=""
SUPPORT_EMAIL="support@nursenest.ca"
# Optional: set true only for CI builds without secrets (not for real production)
# SKIP_EMAIL_ENV_VALIDATION="true"
