{
  "name": "nursenest-core",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "next-auth": {
      "@auth/core": "0.37.2"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && env I18N_QUIET=1 npx tsx scripts/i18n/validate-marketing-i18n.ts && next build",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "eslint",
    "generate:marketing-assets": "node scripts/generate-marketing-assets.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:grant-admin": "tsx scripts/grant-admin-by-email.ts",
    "content:inventory": "tsx scripts/content-inventory.ts",
    "content:quality": "tsx scripts/content-quality-report.ts",
    "content:integrity-audit": "tsx scripts/content-integrity-audit.ts",
    "content:audit-reports": "node scripts/run-content-audit-reports.mjs",
    "import:questions": "tsx scripts/import-questions.ts",
    "import:lessons": "tsx scripts/import-lessons.ts",
    "content:inventory-legacy": "node scripts/inventory-legacy-content.mjs",
    "i18n:sync": "node scripts/i18n/sync-marketing-overlays.mjs",
    "i18n:validate": "tsx scripts/i18n/validate-marketing-i18n.ts",
    "i18n:inventory": "node scripts/i18n/generate-localization-inventory.mjs",
    "i18n:audit": "npx tsx scripts/i18n/validate-marketing-i18n.ts && node scripts/i18n/generate-localization-inventory.mjs"
  },
  "dependencies": {
    "@auth/core": "0.37.2",
    "@auth/prisma-adapter": "^2.10.0",
    "@prisma/client": "^6.7.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@sentry/nextjs": "^10.46.0",
    "bcryptjs": "^2.4.3",
    "lucide-react": "^0.562.0",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.25",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.364.1",
    "posthog-node": "^5.28.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^18.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "esbuild": "^0.25.12",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^6.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5"
  }
}
