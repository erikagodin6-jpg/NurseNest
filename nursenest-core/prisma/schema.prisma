generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CountryCode {
  CA
  US
}

enum TierCode {
  RPN
  LVN_LPN
  RN
  NP
  ALLIED
}

enum UserRole {
  LEARNER
  ADMIN
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum ExamFamily {
  NCLEX_RN
  NCLEX_PN
  REX_PN
  NP
  ALLIED
  GENERIC
}

enum DifficultyBand {
  FOUNDATION
  INTERMEDIATE
  ADVANCED
}

enum QuestionType {
  MCQ
  SATA
  NGN_CASE
  ORDERING
  FIB_NUMERIC
}

enum SubscriptionStatus {
  ACTIVE
  GRACE
  CANCELLED
  PAST_DUE
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ExamSessionStatus {
  IN_PROGRESS
  COMPLETED
}

/** AI-generated content review workflow — never auto-published to learner pools. */
enum DraftReviewStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  PROMOTED
}

model User {
  id                      String         @id @default(cuid())
  email                   String         @unique
  name                    String
  passwordHash            String?
  role                    UserRole       @default(LEARNER)
  country                 CountryCode
  tier                    TierCode
  examFocus               String?
  studyGoal               String?
  dailyStudyMinutes       Int?
  learnerPath             String?
  onboardingCompletedAt   DateTime?
  freeQuestionViews       Int            @default(0)
  freeLessonOpens         Int            @default(0)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  subscriptions           Subscription[]
  attempts                ExamAttempt[]
  examSessions            ExamSession[]
  progress                Progress[]
  aiGenerationJobs        AiGenerationJob[]           @relation("AiJobCreatedBy")
  questionDraftsCreated   GeneratedQuestionDraft[]    @relation("QuestionDraftCreatedBy")
  questionDraftsReviewed  GeneratedQuestionDraft[]    @relation("QuestionDraftReviewedBy")
  flashcardDraftsCreated  GeneratedFlashcardDraft[]   @relation("FlashcardDraftCreatedBy")
  flashcardDraftsReviewed GeneratedFlashcardDraft[]   @relation("FlashcardDraftReviewedBy")
  lessonDraftsCreated     GeneratedLessonDraft[]      @relation("LessonDraftCreatedBy")
  lessonDraftsReviewed    GeneratedLessonDraft[]      @relation("LessonDraftReviewedBy")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String             @unique
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  topicCode String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  lessons   Lesson[]
  questions Question[]
  flashcards Flashcard[]
  generatedQuestionDrafts  GeneratedQuestionDraft[]
  generatedFlashcardDrafts GeneratedFlashcardDraft[]
}

/** Public SEO blog posts (migrated from legacy content_items / static allied data). Separate from Lesson. */
model BlogPost {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  excerpt      String
  body         String   @db.Text
  coverImage   String?
  tags         String[] @default([])
  category     String?
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  /** e.g. content_items, paramedic-static, legacy-json */
  legacySource String?

  @@index([published, createdAt])
}

model Lesson {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  summary     String
  body        String
  country     CountryCode
  tier        TierCode
  status      ContentStatus  @default(DRAFT)
  examFamily  ExamFamily     @default(GENERIC)
  difficulty  DifficultyBand?
  topicTag    String?
  systemTag   String?
  tags        String[]       @default([])
  sourceNotes String?
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  questions   Question[]     @relation("LessonQuestions")
  flashcards  Flashcard[]
  aiQuestionDrafts   GeneratedQuestionDraft[]
  aiFlashcardDrafts  GeneratedFlashcardDraft[]
  lessonEnhancementDrafts GeneratedLessonDraft[] @relation("LessonEnhancementTarget")

  @@index([status, country, tier])
  @@index([categoryId])
}

model Question {
  id            String          @id @default(cuid())
  stem          String
  rationale     String
  options       Json
  answerKey     Json
  questionType  QuestionType
  country       CountryCode
  tier          TierCode
  status        ContentStatus   @default(DRAFT)
  examFamily    ExamFamily      @default(GENERIC)
  difficulty    DifficultyBand?
  topicTag      String?
  systemTag     String?
  tags          String[]        @default([])
  sourceNotes   String?
  generationBatchId String?
  needsReview   Boolean         @default(false)
  duplicateOfId String?
  duplicateOf   Question?       @relation("QuestionDuplicates", fields: [duplicateOfId], references: [id])
  duplicates    Question[]      @relation("QuestionDuplicates")
  stemHash      String?
  categoryId    String
  category      Category        @relation(fields: [categoryId], references: [id])
  lessonId      String?
  lesson        Lesson?         @relation("LessonQuestions", fields: [lessonId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status, country, tier])
  @@index([categoryId])
  @@index([lessonId])
  @@index([examFamily])
  @@index([stemHash])
}

model Flashcard {
  id          String        @id @default(cuid())
  front       String
  back        String
  country     CountryCode
  tier        TierCode
  status      ContentStatus @default(DRAFT)
  examFamily  ExamFamily    @default(GENERIC)
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  lessonId    String?
  lesson      Lesson?       @relation(fields: [lessonId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, country, tier])
  @@index([lessonId])
}

model Exam {
  id          String         @id @default(cuid())
  title       String
  country     CountryCode
  tier        TierCode
  status      ContentStatus  @default(DRAFT)
  examFamily  ExamFamily     @default(GENERIC)
  attempts    ExamAttempt[]
  sessions    ExamSession[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, country, tier])
}

model ExamAttempt {
  id          String        @id @default(cuid())
  userId      String
  examId      String
  score       Int
  total       Int
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam        Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  examSession ExamSession?  @relation("ExamSessionAttempt")

  @@index([examId])
  @@index([userId, createdAt])
}

model ExamSession {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  examId       String?
  exam         Exam?             @relation(fields: [examId], references: [id], onDelete: SetNull)
  questionIds  Json
  answers      Json              @default("{}")
  currentIndex Int               @default(0)
  status       ExamSessionStatus @default(IN_PROGRESS)
  attemptId    String?           @unique
  attempt      ExamAttempt?      @relation("ExamSessionAttempt", fields: [attemptId], references: [id], onDelete: SetNull)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([userId, status])
  @@index([examId])
}

model Progress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model BackgroundJob {
  id           String    @id @default(cuid())
  type         String
  payload      Json
  status       JobStatus @default(PENDING)
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  lastError    String?
  scheduledFor DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, scheduledFor])
  @@index([type])
}

/** One admin AI generation run (batch). */
model AiGenerationJob {
  id             String    @id @default(cuid())
  tool           String
  status         JobStatus @default(COMPLETED)
  model          String?
  sourcePrompt   String    @db.Text
  inputPayload   Json
  resultSummary  Json?
  error          String?   @db.Text
  tokensUsed     Int?
  createdById    String
  createdBy      User      @relation("AiJobCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  logs           AiGenerationLog[]
  questionDrafts GeneratedQuestionDraft[]
  flashcardDrafts GeneratedFlashcardDraft[]
  lessonDrafts   GeneratedLessonDraft[]

  @@index([tool, createdAt])
  @@index([createdById])
}

/** Audit trail for AI steps (granular events under a job). */
model AiGenerationLog {
  id        String          @id @default(cuid())
  jobId     String
  job       AiGenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  step      String
  detail    Json?
  createdAt DateTime        @default(now())

  @@index([jobId])
}

model GeneratedQuestionDraft {
  id               String   @id @default(cuid())
  jobId            String?
  job              AiGenerationJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  tool             String
  batchId          String?
  payloadJson      Json
  normalizedJson   Json?
  validationJson   Json
  reviewStatus     DraftReviewStatus @default(PENDING_REVIEW)
  reviewNotes      String?  @db.Text
  reviewedById     String?
  reviewedBy       User?    @relation("QuestionDraftReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt       DateTime?
  promotedEntityId String?
  promotedAt       DateTime?
  stemHash         String?
  stemPreview      String?
  lessonId         String?
  lesson           Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  categoryId       String?
  category         Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  examFamily       ExamFamily @default(GENERIC)
  tier             TierCode
  country          CountryCode
  sourcePrompt     String   @db.Text
  model            String
  createdById      String
  createdBy        User     @relation("QuestionDraftCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([reviewStatus, createdAt])
  @@index([stemHash])
  @@index([jobId])
  @@index([lessonId])
}

model GeneratedFlashcardDraft {
  id               String   @id @default(cuid())
  jobId            String?
  job              AiGenerationJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  tool             String
  batchId          String?
  payloadJson      Json
  normalizedJson   Json?
  validationJson   Json
  reviewStatus     DraftReviewStatus @default(PENDING_REVIEW)
  reviewNotes      String?  @db.Text
  reviewedById     String?
  reviewedBy       User?    @relation("FlashcardDraftReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt       DateTime?
  promotedEntityId String?
  promotedAt       DateTime?
  frontPreview     String?
  lessonId         String?
  lesson           Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  categoryId       String?
  category         Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  examFamily       ExamFamily @default(GENERIC)
  tier             TierCode
  country          CountryCode
  sourcePrompt     String   @db.Text
  model            String
  createdById      String
  createdBy        User     @relation("FlashcardDraftCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([reviewStatus, createdAt])
  @@index([jobId])
  @@index([lessonId])
}

/** Optional: lesson enhancement / repair drafts — not promoted until review. */
model GeneratedLessonDraft {
  id               String   @id @default(cuid())
  jobId            String?
  job              AiGenerationJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  tool             String
  payloadJson      Json
  normalizedJson   Json?
  validationJson   Json
  reviewStatus     DraftReviewStatus @default(PENDING_REVIEW)
  reviewNotes      String?  @db.Text
  reviewedById     String?
  reviewedBy       User?    @relation("LessonDraftReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt       DateTime?
  promotedEntityId String?
  promotedAt       DateTime?
  titlePreview     String?
  targetLessonId   String?
  targetLesson     Lesson?  @relation("LessonEnhancementTarget", fields: [targetLessonId], references: [id], onDelete: SetNull)
  sourcePrompt     String   @db.Text
  model            String
  createdById      String
  createdBy        User     @relation("LessonDraftCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([reviewStatus, createdAt])
  @@index([jobId])
}
