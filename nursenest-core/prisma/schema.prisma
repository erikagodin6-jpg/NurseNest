generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CountryCode {
  CA
  US
}

enum TierCode {
  RPN
  LVN_LPN
  RN
  NP
  ALLIED
}

enum UserRole {
  LEARNER
  ADMIN
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum ExamFamily {
  NCLEX_RN
  NCLEX_PN
  REX_PN
  NP
  ALLIED
  GENERIC
}

enum DifficultyBand {
  FOUNDATION
  INTERMEDIATE
  ADVANCED
}

enum QuestionType {
  MCQ
  SATA
  NGN_CASE
  ORDERING
  FIB_NUMERIC
}

enum SubscriptionStatus {
  ACTIVE
  GRACE
  CANCELLED
  PAST_DUE
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ExamSessionStatus {
  IN_PROGRESS
  COMPLETED
}

model User {
  id                      String         @id @default(cuid())
  email                   String         @unique
  name                    String
  passwordHash            String?
  /** Incremented on password change / reset to invalidate existing JWTs. */
  authVersion             Int            @default(0)
  role                    UserRole       @default(LEARNER)
  country                 CountryCode
  tier                    TierCode
  examFocus               String?
  studyGoal               String?
  dailyStudyMinutes       Int?
  learnerPath             String?
  onboardingCompletedAt   DateTime?
  freeQuestionViews       Int            @default(0)
  freeLessonOpens         Int            @default(0)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  subscriptions           Subscription[]
  attempts                ExamAttempt[]
  examSessions            ExamSession[]
  progress                Progress[]
  learningProfile         UserLearningProfile?
  passwordResetTokens     PasswordResetToken[]
}

/// Single-use password reset; only tokenHash stored (never raw token).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// Support-assisted "forgot email" / account hints — no automatic email disclosure.
model AccountRecoveryRequest {
  id          String    @id @default(cuid())
  fullName    String
  details     String    @db.Text
  countryHint String?
  tierHint    String?
  last4Hint   String?
  status      String    @default("PENDING")
  handledById String?
  handledAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([status, createdAt])
}

model UserLearningProfile {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  aggregatesBySystem     Json     @default("{}")
  aggregatesByDifficulty Json     @default("{}")
  aggregatesByCategory   Json     @default("{}")
  recentQuestionIds      Json     @default("[]")
  examScoreHistory       Json     @default("[]")
  totalPracticeAttempts  Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([userId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String             @unique
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  topicCode String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  lessons   Lesson[]
  questions Question[]
  flashcards Flashcard[]
}

model Lesson {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  summary     String
  body        String
  country     CountryCode
  tier        TierCode
  status      ContentStatus  @default(DRAFT)
  examFamily  ExamFamily     @default(GENERIC)
  difficulty  DifficultyBand?
  topicTag    String?
  systemTag   String?
  tags        String[]       @default([])
  sourceNotes String?
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  questions   Question[]     @relation("LessonQuestions")
  flashcards  Flashcard[]

  @@index([status, country, tier])
  @@index([categoryId])
}

model Question {
  id            String          @id @default(cuid())
  stem          String
  rationale     String
  options       Json
  answerKey     Json
  questionType  QuestionType
  country       CountryCode
  tier          TierCode
  status        ContentStatus   @default(DRAFT)
  examFamily    ExamFamily      @default(GENERIC)
  difficulty    DifficultyBand?
  topicTag      String?
  systemTag     String?
  tags          String[]        @default([])
  sourceNotes   String?
  generationBatchId String?
  needsReview   Boolean         @default(false)
  duplicateOfId String?
  duplicateOf   Question?       @relation("QuestionDuplicates", fields: [duplicateOfId], references: [id])
  duplicates    Question[]      @relation("QuestionDuplicates")
  stemHash      String?
  categoryId    String
  category      Category        @relation(fields: [categoryId], references: [id])
  lessonId      String?
  lesson        Lesson?         @relation("LessonQuestions", fields: [lessonId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status, country, tier])
  @@index([categoryId])
  @@index([lessonId])
  @@index([examFamily])
  @@index([stemHash])
  @@index([needsReview, status])
}

model Flashcard {
  id          String        @id @default(cuid())
  front       String
  back        String
  country     CountryCode
  tier        TierCode
  status      ContentStatus @default(DRAFT)
  examFamily  ExamFamily    @default(GENERIC)
  needsReview Boolean       @default(false)
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  lessonId    String?
  lesson      Lesson?       @relation(fields: [lessonId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, country, tier])
  @@index([lessonId])
  @@index([needsReview, status])
}

model Exam {
  id          String         @id @default(cuid())
  title       String
  country     CountryCode
  tier        TierCode
  status      ContentStatus  @default(DRAFT)
  examFamily  ExamFamily     @default(GENERIC)
  attempts    ExamAttempt[]
  sessions    ExamSession[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, country, tier])
}

model ExamAttempt {
  id          String        @id @default(cuid())
  userId      String
  examId      String
  score       Int
  total       Int
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam        Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  examSession ExamSession?  @relation("ExamSessionAttempt")

  @@index([examId])
  @@index([userId, createdAt])
}

model ExamSession {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  examId       String?
  exam         Exam?             @relation(fields: [examId], references: [id], onDelete: SetNull)
  questionIds  Json
  answers      Json              @default("{}")
  currentIndex Int               @default(0)
  status       ExamSessionStatus @default(IN_PROGRESS)
  attemptId    String?           @unique
  attempt      ExamAttempt?      @relation("ExamSessionAttempt", fields: [attemptId], references: [id], onDelete: SetNull)
  sessionMeta  Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([userId, status])
  @@index([examId])
}

model Progress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model BackgroundJob {
  id           String    @id @default(cuid())
  type         String
  payload      Json
  status       JobStatus @default(PENDING)
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  lastError    String?
  scheduledFor DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, scheduledFor])
  @@index([type])
}
