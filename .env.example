# Database
DATABASE_URL=postgresql://user:password@localhost:5432/nursenest
# Production deploy (Render, etc.): required when NODE_ENV=production unless you set ALLOW_PROD_FALLBACK_TO_DATABASE_URL=true
PROD_DATABASE_URL=

# Admin API (required at startup — see server/startup-config.ts)
ADMIN_JWT_SECRET=

# Stripe Payment Processing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI API
OPENAI_API_KEY=sk-...

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Session
SESSION_SECRET=your-session-secret-here

# SMTP / Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nursenest.ca

# Analytics
GA_MEASUREMENT_ID=G-XXXXXXXXXX
PLAUSIBLE_DOMAIN=

# Object Storage
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=

# Application
NODE_ENV=production
PORT=5000

# Meta / Social API (optional)
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=

# Google Auth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
