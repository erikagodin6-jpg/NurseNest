# NurseNest Environment Variables
# Copy this file to .env and fill in your values

# ============ DATABASE ============
DATABASE_URL=postgresql://user:password@localhost:5432/nursenest
# PROD_DATABASE_URL=postgresql://user:password@prod-host:5432/nursenest

# ============ SESSION ============
SESSION_SECRET=your-random-session-secret-here

# ============ STRIPE (PAYMENTS) ============
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============ OPENAI (AI FEATURES) ============
OPENAI_API_KEY=sk-your-openai-key-here

# ============ OBJECT STORAGE ============
# PUBLIC_OBJECT_SEARCH_PATHS=/bucket-name/public
# PRIVATE_OBJECT_DIR=/bucket-name/.private

# ============ EMAIL / SMTP ============
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-smtp-password

# ============ ANALYTICS ============
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ============ DOMAIN ============
# DOMAIN=www.nursenest.ca
# BASE_URL=https://www.nursenest.ca

# ============ PAYPAL (OPTIONAL) ============
# PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# ============ NODE ============
NODE_ENV=development
